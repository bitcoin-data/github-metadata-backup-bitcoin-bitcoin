    "maintainer_can_modify": true,
    "title": "doc: Discourage trailing doxygen comments, and fix the broken ones",
    "user": {
      "login": "maflcko",
      "id": 6399679,
      "node_id": "MDQ6VXNlcjYzOTk2Nzk=",
      "avatar_url": "https://avatars.githubusercontent.com/u/6399679?v=4",
      "gravatar_id": "",
