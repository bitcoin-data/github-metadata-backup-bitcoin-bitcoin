      "starred_url": "https://api.github.com/users/spacegeologist/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/spacegeologist/subscriptions",
      "organizations_url": "https://api.github.com/users/spacegeologist/orgs",
      "repos_url": "https://api.github.com/users/spacegeologist/repos",
      "events_url": "https://api.github.com/users/spacegeologist/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/spacegeologist/received_events",
