    "title": "contrib: Retry signet mining after grind failure",
    "user": {
      "login": "spacegeologist",
      "id": 228040220,
      "node_id": "U_kgDODZeeHA",
      "avatar_url": "https://avatars.githubusercontent.com/u/228040220?v=4",
