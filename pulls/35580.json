      "event": "committed",
      "id": null,
      "node_id": "C_kwDOABII59oAKGE5YTRmN2YyYzk2YTNiMmQwZjJmZDU3MWRiMzZhYWQ0OTRmYmQzZjQ",
      "url": "https://api.github.com/repos/bitcoin/bitcoin/git/commits/a9a4f7f2c96a3b2d0f2fd571db36aad494fbd3f4",
