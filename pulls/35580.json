      "tree": {
        "sha": "e88123aaa8a9f8f89234458ebb8f50d87f81ebdf",
        "url": "https://api.github.com/repos/bitcoin/bitcoin/git/trees/e88123aaa8a9f8f89234458ebb8f50d87f81ebdf"
