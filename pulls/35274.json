      "gists_url": "https://api.github.com/users/ImMike/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/ImMike/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/ImMike/subscriptions",
      "organizations_url": "https://api.github.com/users/ImMike/orgs",
      "repos_url": "https://api.github.com/users/ImMike/repos",
