      "organizations_url": "https://api.github.com/users/HouseOfHufflepuff/orgs",
      "repos_url": "https://api.github.com/users/HouseOfHufflepuff/repos",
      "events_url": "https://api.github.com/users/HouseOfHufflepuff/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/HouseOfHufflepuff/received_events",
