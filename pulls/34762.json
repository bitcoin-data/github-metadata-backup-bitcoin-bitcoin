      "body": "style nit (for consistency between cgroup v1 and v2): \n\n```diff\ndiff --git a/src/common/system.cpp b/src/common/system.cpp\nindex 862bcd8a7e..6f309b3797 100644\n--- a/src/common/system.cpp\n+++ b/src/common/system.cpp\n@@ -139,8 +139,10 @@ std::optional<size_t> GetTotalRAM()\n                 if (auto limit{ToIntegral<uint64_t>(val)}) physical_ram = std::min(physical_ram, *limit);\n             }\n         } else if (std::ifstream cg1{\"/sys/fs/cgroup/memory/memory.limit_in_bytes\"}; cg1) {\n-            uint64_t cgroup_limit;\n-            if (cg1 >> cgroup_limit) physical_ram = std::min(physical_ram, cgroup_limit);\n+            std::string val;\n+            if (cg1 >> val) {\n+                if (auto limit{ToIntegral<uint64_t>(val)}) physical_ram = std::min(physical_ram, *limit);\n+            }\n         }\n #endif // __linux__\n         return clamp(physical_ram);\n```",
