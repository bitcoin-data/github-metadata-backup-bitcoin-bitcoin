    "title": "crypto: Add pq1 post-quantum hybrid address (Schnorr + Falcon-1024)",
    "user": {
      "login": "primordialomegazero",
      "id": 267700182,
      "node_id": "U_kgDOD_TH1g",
      "avatar_url": "https://avatars.githubusercontent.com/u/267700182?v=4",
