      "subscriptions_url": "https://api.github.com/users/shuv-amp/subscriptions",
      "organizations_url": "https://api.github.com/users/shuv-amp/orgs",
      "repos_url": "https://api.github.com/users/shuv-amp/repos",
      "events_url": "https://api.github.com/users/shuv-amp/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/shuv-amp/received_events",
