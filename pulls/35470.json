    "locked": false,
    "maintainer_can_modify": true,
    "title": "argsman: Prevent duplicate option registration across categories",
    "user": {
      "login": "pablomartin4btc",
      "id": 110166421,
      "node_id": "U_kgDOBpEBlQ",
      "avatar_url": "https://avatars.githubusercontent.com/u/110166421?v=4",
      "gravatar_id": "",
