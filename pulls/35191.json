      "subscriptions_url": "https://api.github.com/users/ArtSabintsev/subscriptions",
      "organizations_url": "https://api.github.com/users/ArtSabintsev/orgs",
      "repos_url": "https://api.github.com/users/ArtSabintsev/repos",
      "events_url": "https://api.github.com/users/ArtSabintsev/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/ArtSabintsev/received_events",
