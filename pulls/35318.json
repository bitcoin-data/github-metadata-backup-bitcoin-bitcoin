      "gists_url": "https://api.github.com/users/AgusR7/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/AgusR7/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/AgusR7/subscriptions",
      "organizations_url": "https://api.github.com/users/AgusR7/orgs",
      "repos_url": "https://api.github.com/users/AgusR7/repos",
      "events_url": "https://api.github.com/users/AgusR7/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/AgusR7/received_events",
      "type": "User",
