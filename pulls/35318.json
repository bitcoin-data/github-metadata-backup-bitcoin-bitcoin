    "title": "fuzz: Bound package eval tx fanout",
    "user": {
      "login": "AgusR7",
      "id": 115115689,
      "node_id": "U_kgDOBtyGqQ",
      "avatar_url": "https://avatars.githubusercontent.com/u/115115689?v=4",
