      "node_id": "C_kwDOABII59oAKDVmNzRiN2ZmMWQyNTM2OWNmYzQxZjIxZDhmMjk4YjQ4NGJjNzVmM2Q",
      "url": "https://api.github.com/repos/bitcoin/bitcoin/git/commits/5f74b7ff1d25369cfc41f21d8f298b484bc75f3d",
      "actor": null,
      "commit_id": null,
      "commit_url": null,
      "created_at": null,
      "html_url": "https://github.com/bitcoin/bitcoin/commit/5f74b7ff1d25369cfc41f21d8f298b484bc75f3d",
      "tree": {
        "sha": "8829ff8e2e70a9678e49e1f9a54eac49c435d8e4",
        "url": "https://api.github.com/repos/bitcoin/bitcoin/git/trees/8829ff8e2e70a9678e49e1f9a54eac49c435d8e4"
      },
      "verification": {
        "verified": true,
        "reason": "valid",
        "payload": "tree 8829ff8e2e70a9678e49e1f9a54eac49c435d8e4\nparent 561d072e0590179f1c60bb2784077589812a05bb\nauthor Cory Fields <cory-nospam-@coryfields.com> 1777399236 +0000\ncommitter fanquake <fanquake@gmail.com> 1777537981 +0100\n\nmulti_index: fix compilation failure with boost >= 1.91\n\nThis effectively reverts a3cb309e7c31853f272bffaa65fb6ab0a7cc4083 from PR #30194.\n\nThat PR reduced the multi_index type signatures as recommended upstream, but\nthis is no longer supported as of boost 1.91 because it is no longer necessary.\n1.91 drops support for the pre-c++11 work-arounds that bloated the type\nsignatures to begin with.\n\nThe upstream `BOOST_MULTI_INDEX_ENABLE_MPL_SUPPORT` define is meant to provide\ncompatibility with removed features, but it does not work for this case. Using\n`indexed_by` directly when defining the `multi_index` (as opposed to inheriting\nfrom it) works with all versions, and avoids the use of the back-compat define.\n\nThis is a slight regression when building against boost < 1.91 because the\nbloated type signatures are reintroduced in that case, but it's not significant\nenough to go to the trouble of introducing version detection and ifdefs.\n\nGithub-Pull: #35175\nRebased-From: 0bc9d354dfd8074d1c36a891a69b6585a8775c65\n",
        "signature": "-----BEGIN PGP SIGNATURE-----\n\niQJPBAABCAA5FiEEz7FuIclQ9n+pXlWPLuufXMCVJsEFAmnzE70bFIAAAAAABAAO\nbWFudTIsMi41KzEuMTIsMCwzAAoJEC7rn1zAlSbB3egQAJmAIYcdPW0o8XXYUunF\nwwptCTFeQALkzPLSgStufAITd2FMY/bxRp6ycGj0wqiboGBrCpIbqtzHHdm1X9m4\nPKLXrJ2VOubz8l7lhxg7y3llRo3v5ZZOvYsfzAMr+v6WdCHeov9fud7MLKZuLUB4\nNN0TrA1HiK+5m6xAIe9W0STBApDBKpKG0P3Om8R0ouyLmJMPdHCmKORG3oh0AxIm\ntaOwp5F4JXY2c0va8AbLQH6UH7AOGRHjbbiA0TB7P07dbWxICamyCsQvmGJpcUkq\nm4au5NUqOjIcTZ9QcY4rZr3ZOyoVGyk7xcfWNSiT3F5i7dv4f0MtBZ6tyXlhcBF2\nz6Vh/3PxdqUx47BD28UhnS61jVyxp8BDyFByHutD/82s5jvQiS7FlMQ4Jkex6Kuw\ncSolm+H41c+OeLQ6rGODJQEsMtZbXCaosJdqln+C2DF3yAtkwL1QIvrR9zdjuenA\nqztTwr71MpiL1tNYJJbWz3UeA/bmJTD3y7W9yhWM2PF+aXtzlcQvjLy7oLx9M57F\nZThcees7lUdwb+4FohaLREsN1e/ol0/Eh5U7dhaaWLgdMcbVC9pdnwQc/UzA7xR7\nELTk1VN37N8mqwPr2rhmYNCnx2CcOfsGbgxrNca+WuLD/oWPxss4qKETgH+Q4/rN\nT0RCqoAoEcfztpR1EO3DwnwE\n=PkeI\n-----END PGP SIGNATURE-----"
