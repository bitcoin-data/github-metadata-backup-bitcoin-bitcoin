    "title": "rpc: add prev_txs param to utxoupdatepsbt",
    "user": {
      "login": "bittoby",
      "id": 218712309,
      "node_id": "U_kgDODQlI9Q",
      "avatar_url": "https://avatars.githubusercontent.com/u/218712309?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/bittoby",
      "html_url": "https://github.com/bittoby",
      "followers_url": "https://api.github.com/users/bittoby/followers",
      "following_url": "https://api.github.com/users/bittoby/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/bittoby/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/bittoby/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/bittoby/subscriptions",
      "organizations_url": "https://api.github.com/users/bittoby/orgs",
      "repos_url": "https://api.github.com/users/bittoby/repos",
      "events_url": "https://api.github.com/users/bittoby/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/bittoby/received_events",
      "type": "User",
