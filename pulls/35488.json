      "starred_url": "https://api.github.com/users/opus-lux/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/opus-lux/subscriptions",
      "organizations_url": "https://api.github.com/users/opus-lux/orgs",
      "repos_url": "https://api.github.com/users/opus-lux/repos",
      "events_url": "https://api.github.com/users/opus-lux/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/opus-lux/received_events",
