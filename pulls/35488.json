    "title": "P2WOTS: 64 Slot Winternitz Output Type (witness version three)",
    "user": {
      "login": "opus-lux",
      "id": 280077999,
      "node_id": "U_kgDOELGmrw",
      "avatar_url": "https://avatars.githubusercontent.com/u/280077999?v=4",
