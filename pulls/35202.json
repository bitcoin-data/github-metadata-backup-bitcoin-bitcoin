    "maintainer_can_modify": true,
    "title": "test: skip `sock_tests` when `socketcall` is blocked on x86-32",
    "user": {
      "login": "l0rinc",
      "id": 1841944,
      "node_id": "MDQ6VXNlcjE4NDE5NDQ=",
      "avatar_url": "https://avatars.githubusercontent.com/u/1841944?v=4",
