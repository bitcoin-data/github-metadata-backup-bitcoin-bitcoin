    "title": "wallet: importdescriptors: report per-item error for invalid timestamp",
    "user": {
      "login": "taserz",
      "id": 852984,
      "node_id": "MDQ6VXNlcjg1Mjk4NA==",
      "avatar_url": "https://avatars.githubusercontent.com/u/852984?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/taserz",
      "html_url": "https://github.com/taserz",
      "followers_url": "https://api.github.com/users/taserz/followers",
      "following_url": "https://api.github.com/users/taserz/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/taserz/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/taserz/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/taserz/subscriptions",
      "organizations_url": "https://api.github.com/users/taserz/orgs",
      "repos_url": "https://api.github.com/users/taserz/repos",
      "events_url": "https://api.github.com/users/taserz/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/taserz/received_events",
