      "body": "ACK 12c3c3f81d52b852cf51b549a5de4d55b0ed624b\r\n\r\nYou could also make this cover the IPC [CoinbaseTx](https://github.com/bitcoin/bitcoin/blob/master/src/ipc/capnp/mining.capnp#L59-L67) struct:\r\n\r\n```diff\r\n--- a/src/rpc/mining.cpp\r\n+++ b/src/rpc/mining.cpp\r\n@@ -999,5 +999,6 @@ static RPCHelpMan getblocktemplate()\r\n     result.pushKV(\"transactions\", std::move(transactions));\r\n     result.pushKV(\"coinbaseaux\", std::move(aux));\r\n-    result.pushKV(\"coinbasevalue\", block.vtx[0]->vout[0].nValue);\r\n+    const auto coinbase{block_template->getCoinbaseTx()};\r\n+    result.pushKV(\"coinbasevalue\", coinbase.block_reward_remaining);\r\n     result.pushKV(\"longpollid\", tip.GetHex() + ToString(nTransactionsUpdatedLast));\r\n     result.pushKV(\"target\", hashTarget.GetHex());\r\n@@ -1026,5 +1027,5 @@ static RPCHelpMan getblocktemplate()\r\n     }\r\n\r\n-    if (auto coinbase{block_template->getCoinbaseTx()}; coinbase.required_outputs.size() > 0) {\r\n+    if (coinbase.required_outputs.size() > 0) {\r\n         CHECK_NONFATAL(coinbase.required_outputs.size() == 1); // Only one output is currently expected\r\n         result.pushKV(\"default_witness_commitment\", HexStr(coinbase.required_outputs[0].scriptPubKey));\r\n```",
