      "body": "utACK 1c1de334e9c0e3b4c72c3f3fe45b1f4df5ce4502\r\n\r\nThis is a fix for an identified sporadic CI failure, due to a race condition, due to a quick create-and-destroy of a capnp context. The change is test-only and limited. Instead of calling into the `make_capnp_init_ctx` util, only its needed part is inlined. Verified by code review and unit tests.\r\n",
      "user": {
        "login": "optout21",
        "id": 13562139,
        "node_id": "MDQ6VXNlcjEzNTYyMTM5",
        "avatar_url": "https://avatars.githubusercontent.com/u/13562139?v=4",
        "gravatar_id": "",
        "url": "https://api.github.com/users/optout21",
        "html_url": "https://github.com/optout21",
        "followers_url": "https://api.github.com/users/optout21/followers",
