      "subscriptions_url": "https://api.github.com/users/digin1/subscriptions",
      "organizations_url": "https://api.github.com/users/digin1/orgs",
      "repos_url": "https://api.github.com/users/digin1/repos",
      "events_url": "https://api.github.com/users/digin1/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/digin1/received_events",
