    "title": "refactor: Harden prevector::change_capacity against capacity < size",
    "user": {
      "login": "asafmod",
      "id": 34423469,
      "node_id": "MDQ6VXNlcjM0NDIzNDY5",
      "avatar_url": "https://avatars.githubusercontent.com/u/34423469?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/asafmod",
      "html_url": "https://github.com/asafmod",
      "followers_url": "https://api.github.com/users/asafmod/followers",
      "following_url": "https://api.github.com/users/asafmod/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/asafmod/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/asafmod/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/asafmod/subscriptions",
      "organizations_url": "https://api.github.com/users/asafmod/orgs",
      "repos_url": "https://api.github.com/users/asafmod/repos",
      "events_url": "https://api.github.com/users/asafmod/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/asafmod/received_events",
      "type": "User",
