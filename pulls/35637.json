      "html_url": "https://github.com/tuna4ll",
      "followers_url": "https://api.github.com/users/tuna4ll/followers",
      "following_url": "https://api.github.com/users/tuna4ll/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/tuna4ll/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/tuna4ll/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/tuna4ll/subscriptions",
      "organizations_url": "https://api.github.com/users/tuna4ll/orgs",
      "repos_url": "https://api.github.com/users/tuna4ll/repos",
      "events_url": "https://api.github.com/users/tuna4ll/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/tuna4ll/received_events",
