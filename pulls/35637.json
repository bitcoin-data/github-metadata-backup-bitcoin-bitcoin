    "title": "rpc: allow multiple data outputs",
    "user": {
      "login": "tuna4ll",
      "id": 66411462,
      "node_id": "MDQ6VXNlcjY2NDExNDYy",
      "avatar_url": "https://avatars.githubusercontent.com/u/66411462?v=4",
      "gravatar_id": "",
