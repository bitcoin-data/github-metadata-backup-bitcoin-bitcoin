    "title": "wallet: Check only our inputs for multisig wallets",
    "user": {
      "login": "Bicaru20",
      "id": 91594426,
      "node_id": "U_kgDOBXWeug",
      "avatar_url": "https://avatars.githubusercontent.com/u/91594426?v=4",
