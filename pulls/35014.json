    "maintainer_can_modify": true,
    "title": "ipc: fix exception type visibility with REDUCE_EXPORTS on macOS",
    "user": {
      "login": "alfonsoromanz",
      "id": 19962151,
      "node_id": "MDQ6VXNlcjE5OTYyMTUx",
