    "maintainer_can_modify": true,
    "title": "net: Warn when Tor onion service lacks a dedicated onion bind",
    "user": {
      "login": "HouseOfHufflepuff",
      "id": 896651,
      "node_id": "MDQ6VXNlcjg5NjY1MQ==",
