      "following_url": "https://api.github.com/users/cryptomentor-de/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/cryptomentor-de/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/cryptomentor-de/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/cryptomentor-de/subscriptions",
      "organizations_url": "https://api.github.com/users/cryptomentor-de/orgs",
      "repos_url": "https://api.github.com/users/cryptomentor-de/repos",
      "events_url": "https://api.github.com/users/cryptomentor-de/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/cryptomentor-de/received_events",
