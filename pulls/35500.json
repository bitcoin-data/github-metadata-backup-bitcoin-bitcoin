    "title": "wallet: check WriteMasterKey result when changing passphrase",
    "user": {
      "login": "cryptomentor-de",
      "id": 227346299,
      "node_id": "U_kgDODY0Hew",
      "avatar_url": "https://avatars.githubusercontent.com/u/227346299?v=4",
