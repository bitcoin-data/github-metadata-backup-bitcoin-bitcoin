      "subscriptions_url": "https://api.github.com/users/RobertoFilho0100/subscriptions",
      "organizations_url": "https://api.github.com/users/RobertoFilho0100/orgs",
      "repos_url": "https://api.github.com/users/RobertoFilho0100/repos",
      "events_url": "https://api.github.com/users/RobertoFilho0100/events%7B/privacy%7D",
