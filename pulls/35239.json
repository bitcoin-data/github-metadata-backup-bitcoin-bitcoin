      "subscriptions_url": "https://api.github.com/users/IsmaelBuilds/subscriptions",
      "organizations_url": "https://api.github.com/users/IsmaelBuilds/orgs",
      "repos_url": "https://api.github.com/users/IsmaelBuilds/repos",
      "events_url": "https://api.github.com/users/IsmaelBuilds/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/IsmaelBuilds/received_events",
