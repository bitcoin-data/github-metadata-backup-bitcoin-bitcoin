    "title": "wallet: batch per-block writes in a single SQLite transaction",
    "user": {
      "login": "IsmaelBuilds",
      "id": 98184738,
      "node_id": "U_kgDOBdouIg",
      "avatar_url": "https://avatars.githubusercontent.com/u/98184738?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/IsmaelBuilds",
      "html_url": "https://github.com/IsmaelBuilds",
      "followers_url": "https://api.github.com/users/IsmaelBuilds/followers",
      "following_url": "https://api.github.com/users/IsmaelBuilds/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/IsmaelBuilds/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/IsmaelBuilds/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/IsmaelBuilds/subscriptions",
      "organizations_url": "https://api.github.com/users/IsmaelBuilds/orgs",
      "repos_url": "https://api.github.com/users/IsmaelBuilds/repos",
      "events_url": "https://api.github.com/users/IsmaelBuilds/events%7B/privacy%7D",
      "received_events_url": "https://api.github.com/users/IsmaelBuilds/received_events",
