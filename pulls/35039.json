      "tree": {
        "sha": "a7555daaa590fc66ccdd1823b81f76eecf765627",
        "url": "https://api.github.com/repos/bitcoin/bitcoin/git/trees/a7555daaa590fc66ccdd1823b81f76eecf765627"
