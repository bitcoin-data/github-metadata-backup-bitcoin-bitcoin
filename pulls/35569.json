    "title": "Making CTransaction a Regular Type",
    "user": {
      "login": "purpleKarrot",
      "id": 185240,
      "node_id": "MDQ6VXNlcjE4NTI0MA==",
      "avatar_url": "https://avatars.githubusercontent.com/u/185240?v=4",
